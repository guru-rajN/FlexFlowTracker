{
  "entities": {
    "GlobalStats": {
      "title": "Global Metrics",
      "description": "Aggregated application telemetry",
      "type": "object",
      "properties": {
        "userCount": { "type": "number" },
        "activeProtocols": { "type": "number" }
      },
      "required": ["userCount"]
    },
    "WeightLog": {
      "title": "Weight Entry",
      "description": "Snapshots of user body weight over time",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "weight": { "type": "number" },
        "date": { "type": "string", "format": "date" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "weight", "date", "createdAt"]
    },
    "Testimonial": {
      "title": "Protocol Testimony",
      "description": "User feedback and rating",
      "type": "object",
      "properties": {
        "userName": { "type": "string" },
        "avatar": { "type": "string" },
        "content": { "type": "string" },
        "rating": { "type": "number", "minimum": 1, "maximum": 5 },
        "role": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["userName", "content", "rating"]
    },
    "UserProfile": {
      "title": "User Profile",
      "description": "Storage for user goals and personal information",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "displayName": { "type": "string" },
        "isCounted": { "type": "boolean" },
        "dailyCalorieGoal": { "type": "number" },
        "dailyProteinGoal": { "type": "number" },
        "weight": { "type": "number" },
        "height": { "type": "number" },
        "age": { "type": "number" },
        "gender": { "type": "string", "enum": ["male", "female", "other"] },
        "activityLevel": { "type": "string", "enum": ["sedentary", "light", "moderate", "active", "very_active"] },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["uid", "dailyCalorieGoal"]
    },
    "MealLog": {
      "title": "Meal Log",
      "description": "Daily food intake record",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "date": { "type": "string", "format": "date" },
        "name": { "type": "string" },
        "category": { "type": "string", "enum": ["breakfast", "lunch", "dinner", "snacks"] },
        "calories": { "type": "number" },
        "protein": { "type": "number" },
        "carbs": { "type": "number" },
        "fats": { "type": "number" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "date", "name", "calories", "category"]
    },
    "Workout": {
      "title": "Workout Session",
      "description": "Record of a gym or home workout",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "date": { "type": "string", "format": "date" },
        "name": { "type": "string" },
        "sets": { "type": "number" },
        "reps": { "type": "number" },
        "weightLifted": { "type": "number" },
        "caloriesBurned": { "type": "number" },
        "duration": { "type": "number" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "date", "name"]
    },
    "Exercise": {
      "title": "Exercise",
      "description": "Individual exercise within a workout",
      "type": "object",
      "properties": {
        "workoutId": { "type": "string" },
        "name": { "type": "string" },
        "notes": { "type": "string" }
      },
      "required": ["workoutId", "name"]
    },
    "Set": {
      "title": "Set",
      "description": "Individual set of an exercise",
      "type": "object",
      "properties": {
        "exerciseId": { "type": "string" },
        "reps": { "type": "number" },
        "weight": { "type": "number" }
      },
      "required": ["exerciseId", "reps", "weight"]
    },
    "HealthCheck": {
      "title": "Health Check",
      "description": "Minimal document for connectivity verification",
      "type": "object",
      "properties": {
        "status": { "type": "string" }
      }
    }
  },
  "firestore": {
    "profiles": {
      "schema": "UserProfile",
      "description": "User profile collection"
    },
    "meals": {
      "schema": "MealLog",
      "description": "Meal logs collection"
    },
    "workouts": {
      "schema": "Workout",
      "description": "Workout sessions collection"
    },
    "workouts/{workoutId}/exercises": {
      "schema": "Exercise",
      "description": "Exercises in a workout"
    },
    "workouts/{workoutId}/exercises/{exerciseId}/sets": {
      "schema": "Set",
      "description": "Sets for an exercise"
    },
    "weightLogs": {
      "schema": "WeightLog",
      "description": "Historical body weight tracking"
    },
    "stats": {
      "schema": "GlobalStats",
      "description": "Global application telemetry"
    },
    "testimonials": {
      "schema": "Testimonial",
      "description": "Public user testimonials"
    },
    "test": {
      "schema": "HealthCheck",
      "description": "Connection probe path"
    }
  }
}
