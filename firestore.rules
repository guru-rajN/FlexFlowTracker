rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Default deny
    match /{document=**} {
      allow read, write: if false;
    }

    // Helper functions
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    // Profiles
    match /profiles/{profileId} {
      allow read: if isOwner(profileId);
      allow create, update: if isOwner(profileId) 
        && request.resource.data.keys().hasAll(['uid', 'dailyCalorieGoal'])
        && request.resource.data.uid == request.auth.uid;
    }

    // Meals
    match /meals/{mealId} {
      function isValidMeal(data) {
        return data.userId == request.auth.uid
          && data.name is string && data.name.size() <= 200
          && data.calories is number
          && data.date is string && data.date.size() == 10;
      }
      
      allow list: if isSignedIn() && resource.data.userId == request.auth.uid;
      allow get: if isSignedIn() && resource.data.userId == request.auth.uid;
      allow create: if isSignedIn() && isValidMeal(request.resource.data);
      allow delete: if isSignedIn() && resource.data.userId == request.auth.uid;
    }

    // Workouts
    match /workouts/{workoutId} {
      function isValidWorkout(data) {
        return data.userId == request.auth.uid
          && data.name is string && data.name.size() <= 100
          && data.date is string && data.date.size() == 10;
      }

      allow list: if isSignedIn() && resource.data.userId == request.auth.uid;
      allow get: if isSignedIn() && resource.data.userId == request.auth.uid;
      allow create: if isSignedIn() && isValidWorkout(request.resource.data);
      allow delete: if isSignedIn() && resource.data.userId == request.auth.uid;

      // Subcollections
      match /exercises/{exerciseId} {
        allow read, write: if isSignedIn() && get(/databases/$(database)/documents/workouts/$(workoutId)).data.userId == request.auth.uid;
      }
    }

    // Weight Logs
    match /weightLogs/{logId} {
      function isValidWeightLog(data) {
        return data.userId == request.auth.uid
          && data.weight is number
          && data.date is string && data.date.size() == 10;
      }
      
      allow list: if isSignedIn() && resource.data.userId == request.auth.uid;
      allow get: if isSignedIn() && resource.data.userId == request.auth.uid;
      allow create: if isSignedIn() && isValidWeightLog(request.resource.data);
      allow delete: if isSignedIn() && resource.data.userId == request.auth.uid;
    }
  }
}
